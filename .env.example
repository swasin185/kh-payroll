# =========================================================================
# KH Payroll Environment Variables Template (Copy to .env for customization)
# =========================================================================

# --- Node & Server Environment ---
# Node environment. Use 'development' for local development or 'production' for release builds.
NODE_ENV=production

# The host the Nuxt server binds to.
NITRO_HOST=127.0.0.1

# The port the Nuxt server listens on.
NITRO_PORT=3000

# Disable TLS rejection for internal self-signed certificates (set to 0 to disable, 1 to enable).
NODE_TLS_REJECT_UNAUTHORIZED=0

# --- Database Configuration ---
# MariaDB/MySQL database connection settings.
DB_HOST=10.0.0.245
DB_PORT=3306
DB_USER=pr-user
DB_PASSWORD=A1b2C3d4#
DB_NAME=payroll
DB_CONNECTION_LIMIT=100

# --- Redis Configuration ---
# Optional Redis connection string for session storage.
# If left blank, Nuxt config defaults to using memory-based session storage.
# REDIS_URL=redis://127.0.0.1:6379

# --- Session & Security Configuration ---
# Session maximum lifetime in seconds. (Defaults to 36000)
# Note: Client-side idle limit is automatically calculated as MAX_AGE / 10 (defaults to 3600).
MAX_AGE=36000

# Session encryption password. Must be a secure string of at least 32 characters.
# Fallback is: 1234567_1234567_1234567_12345678
NUXT_SESSION_PASSWORD=1234567_1234567_1234567_12345678

# --- Proxy / Report API Configuration ---
# Target endpoints for proxying /kxreport/** traffic.
# Defaults to http://127.0.0.1:8080/kxreport/** if not specified.
KXREPORT=http://127.0.0.1:8080/kxreport/**
KXREPORT_HTTPS=https://127.0.0.1:8443/kxreport/**
